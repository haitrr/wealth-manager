generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accounts             Account[]
  transactionCategories TransactionCategory[]
  transactions         Transaction[]
  budgets              Budget[]
  exchangeRates        ExchangeRate[]
  apiKeys              ApiKey[]
  loans                Loan[]
  loanPayments         LoanPayment[]
}

enum Currency {
  USD
  VND
}

model Account {
  id           String        @id @default(cuid())
  name         String
  balance      Float         @default(0)
  currency     Currency      @default(USD)
  isDefault    Boolean       @default(false)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  loans        Loan[]
  loanPayments LoanPayment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum LoanDirection {
  borrowed
  lent
}

enum LoanStatus {
  active
  closed
}

enum CategoryType {
  income
  expense
}

model TransactionCategory {
  id                   String                @id @default(cuid())
  name                 String
  icon                 String?
  type                 CategoryType
  userId               String
  parentId             String?
  parent               TransactionCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children             TransactionCategory[] @relation("CategoryChildren")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]
  loanPrincipalConfig  Loan[]                @relation("LoanPrincipalCategory")
  loanInterestConfig   Loan[]                @relation("LoanInterestCategory")
  loanPrepayFeeConfig  Loan[]                @relation("LoanPrepayFeeCategory")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Transaction {
  id                   String              @id @default(cuid())
  amount               Float
  date                 DateTime
  description          String?
  details              String?
  accountId            String
  account              Account             @relation(fields: [accountId], references: [id])
  categoryId           String
  category             TransactionCategory @relation(fields: [categoryId], references: [id])
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanPaymentPrincipal LoanPayment?        @relation("LoanPrincipalTransaction")
  loanPaymentInterest  LoanPayment?        @relation("LoanInterestTransaction")
  loanPaymentPrepayFee LoanPayment?        @relation("LoanPrepayFeeTransaction")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Loan {
  id               String        @id @default(cuid())
  name             String
  direction        LoanDirection
  principalAmount  Float
  currency         Currency      @default(USD)
  startDate        DateTime
  counterpartyName String?
  notes            String?
  status           LoanStatus    @default(active)
  accountId           String
  account             Account              @relation(fields: [accountId], references: [id])
  principalCategoryId String?
  principalCategory   TransactionCategory? @relation("LoanPrincipalCategory", fields: [principalCategoryId], references: [id])
  interestCategoryId  String?
  interestCategory    TransactionCategory? @relation("LoanInterestCategory", fields: [interestCategoryId], references: [id])
  prepayFeeCategoryId String?
  prepayFeeCategory   TransactionCategory? @relation("LoanPrepayFeeCategory", fields: [prepayFeeCategoryId], references: [id])
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments            LoanPayment[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId, status])
  @@index([accountId])
}

model LoanPayment {
  id                     String       @id @default(cuid())
  loanId                 String
  loan                   Loan         @relation(fields: [loanId], references: [id], onDelete: Cascade)
  accountId              String
  account                Account      @relation(fields: [accountId], references: [id])
  paymentDate            DateTime
  principalTransactionId String?      @unique
  principalTransaction   Transaction? @relation("LoanPrincipalTransaction", fields: [principalTransactionId], references: [id], onDelete: SetNull)
  interestTransactionId  String?      @unique
  interestTransaction    Transaction? @relation("LoanInterestTransaction", fields: [interestTransactionId], references: [id], onDelete: SetNull)
  prepayFeeTransactionId String?      @unique
  prepayFeeTransaction   Transaction? @relation("LoanPrepayFeeTransaction", fields: [prepayFeeTransactionId], references: [id], onDelete: SetNull)
  note                   String?
  userId                 String
  user                   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([loanId, paymentDate])
  @@index([userId])
}

model Budget {
  id                  String    @id @default(cuid())
  name                String
  amount              Float
  currency            Currency  @default(USD)
  period              String
  startDate           DateTime
  endDate             DateTime?
  accountId           String?
  account             Account?  @relation(fields: [accountId], references: [id])
  categoryIds         String[]  @default([])
  excludedCategoryIds String[]  @default([])
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency Currency
  toCurrency   Currency
  rate         Float
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, fromCurrency, toCurrency])
}
